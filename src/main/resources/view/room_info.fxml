<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600" prefWidth="900" styleClass="root-pane" stylesheets="/css/room_info.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.Room_Info">

    <children>

        <!-- Card container -->
        <VBox alignment="TOP_CENTER" layoutX="104.0" layoutY="70.0" prefHeight="460" prefWidth="672.0" spacing="15" styleClass="room-card">

            <!-- Title -->
            <Label styleClass="room-title" text="Room Information">
                <font>
                    <Font name="System Bold" size="26.0" />
                </font>
            </Label>

            <!-- Top input fields -->
            <HBox alignment="CENTER" spacing="10">
                <TextField fx:id="txtRoomId" promptText="Room ID" styleClass="room-input" />
                <TextField fx:id="txtType" promptText="Type" styleClass="room-input" />
                <TextField fx:id="txtDesc" promptText="Description" styleClass="room-input" />
                <TextField fx:id="txtPrice" promptText="Price" styleClass="room-input" />
            </HBox>

            <!-- Buttons -->
            <HBox alignment="CENTER" spacing="15">
                <Button fx:id="btnAdd" onAction="#btnAddOnAction" styleClass="room-button" text="Add" />
                <Button fx:id="btnUpdate" onAction="#btnUpdateOnAction" styleClass="room-button" text="Update" />
                <Button fx:id="btnDelete" onAction="#btnDeleteOnAction" styleClass="room-button" text="Delete" />
                <Button fx:id="btnClear" onAction="#btnClearOnAction" styleClass="room-button" text="Clear" />
            </HBox>

            <!-- Table -->
            <TableView fx:id="tblRoomInfo" prefHeight="264.0" prefWidth="646.0" styleClass="room-table">
                <columns>
                    <TableColumn fx:id="columnRoomId" prefWidth="96.80001068115234" text="Room ID" />
                    <TableColumn fx:id="columnType" prefWidth="114.4000244140625" text="Type" />
                    <TableColumn fx:id="columnDescription" prefWidth="234.39999389648438" text="Description" />
                    <TableColumn fx:id="columnPrice" prefWidth="142.4000244140625" text="Price" />
                </columns>
            </TableView>

            <!-- Reload Button -->
            <Button fx:id="btnReload" onAction="#btnReloadOnAction" styleClass="reload-button" text="Reload" />

        </VBox>
    </children>
</AnchorPane>
