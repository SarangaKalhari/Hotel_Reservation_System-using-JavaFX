<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="414.0" prefWidth="468.0"
            style="-fx-border-radius: 20px; -fx-background-color: #4f5459;"
            xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.LoginFormController">

    <children>
        <!-- Title -->
        <Label layoutX="138.0" layoutY="36.0"
               prefHeight="54.0" prefWidth="191.0"
               text="Login Form" textFill="#f2eaea">
            <font>
                <Font name="System Bold Italic" size="36.0" />
            </font>
        </Label>

        <!-- Username field -->
        <TextField fx:id="txtUserName"
                   layoutX="113.0" layoutY="141.0"
                   prefHeight="35.0" prefWidth="242.0"
                   promptText="User Name"
                   style="-fx-background-radius: 20px; -fx-padding: 8 12; -fx-background-color: #ffffff;" />

        <!-- Password field -->
        <PasswordField fx:id="txtPassword"
                       layoutX="113.0" layoutY="207.0"
                       prefHeight="35.0" prefWidth="242.0"
                       promptText="Password"
                       style="-fx-background-radius: 20px; -fx-padding: 8 12; -fx-background-color: #ffffff;" />

        <!-- Login button -->
        <Button fx:id="btnLogin"
                layoutX="189.0" layoutY="285.0"
                mnemonicParsing="false"
                onAction="#btnLoginOnAction"
                prefHeight="34.0" prefWidth="89.0"
                text="Login"
                textFill="#383535"
                style="-fx-background-color: #42f57b; -fx-background-radius: 20px;">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Button>

        <!-- Optional status label -->
        <Label fx:id="lblStatus"
               layoutX="150.0" layoutY="340.0"
               textFill="#ffb3b3"
               style="-fx-font-size: 13px;" />
    </children>

</AnchorPane>
