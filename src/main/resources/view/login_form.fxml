<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="388.0" style="-fx-border-radius: 20px; -fx-background-color: #4f5459;" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginFormController">
   <children>
      <Label layoutX="93.0" layoutY="34.0" prefHeight="54.0" prefWidth="191.0" style="-fx-font: #4295f5;" text="Login Form" textFill="#f2eaea">
         <font>
            <Font name="System Bold Italic" size="36.0" />
         </font>
      </Label>
      <TextField fx:id="txtUserName" layoutX="68.0" layoutY="124.0" prefHeight="6.0" prefWidth="242.0" promptText="User Name" />
      <TextField fx:id="txtPassword" layoutX="68.0" layoutY="188.0" prefHeight="9.0" prefWidth="242.0" promptText="Password" />
      <Button layoutX="137.0" layoutY="270.0" mnemonicParsing="false" onAction="#btnLoginOnAction" prefHeight="34.0" prefWidth="89.0" style="-fx-background-color: #42f57b;" text="Login" textFill="#383535">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
