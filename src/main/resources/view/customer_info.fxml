<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600" prefWidth="900" styleClass="root-pane" stylesheets="/css/customer_info.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.Customer_Info">

    <children>

        <!-- Card container -->
        <VBox alignment="TOP_CENTER" layoutX="100.0" layoutY="50.0" prefWidth="700.0" spacing="15" styleClass="customer-card">

            <!-- Title -->
            <Label styleClass="card-title" text="Customer Information">
                <font>
                    <Font name="System Bold" size="26.0" />
                </font>
            </Label>

            <!-- Input Fields -->
            <HBox alignment="CENTER" spacing="10">
                <TextField fx:id="txtCustID" promptText="Customer ID" styleClass="card-input" />
                <TextField fx:id="txtName" promptText="Name" styleClass="card-input" />
                <TextField fx:id="txtAge" promptText="Age" styleClass="card-input" />
                <TextField fx:id="txtPhoneNumber" promptText="Phone Number" styleClass="card-input" />
                <TextField fx:id="txtCity" promptText="City" styleClass="card-input" />
            </HBox>

            <!-- Buttons -->
            <HBox alignment="CENTER" spacing="15">
                <Button fx:id="btnAdd" onAction="#btnAddOnAction" styleClass="card-button" text="Add" />
                <Button fx:id="btnUpdate" onAction="#btnUpdateOnAction" styleClass="card-button" text="Update" />
                <Button fx:id="btnDelete" onAction="#btnDeleteOnAction" styleClass="card-button" text="Delete" />
                <Button fx:id="btnClear" onAction="#btnClearOnAction" styleClass="card-button" text="Clear" />
            </HBox>

            <!-- Table -->
            <TableView fx:id="tblCustomeInfo" prefHeight="222.0" prefWidth="655.0" styleClass="card-table">
                <columns>
                    <TableColumn fx:id="colCustID" prefWidth="100.0" text="ID" />
                    <TableColumn fx:id="colCustName" prefWidth="150.0" text="Name" />
                    <TableColumn fx:id="colCustAge" prefWidth="70.0" text="Age" />
                    <TableColumn fx:id="colCustPhoneNo" prefWidth="180.0" text="Phone Number" />
                    <TableColumn fx:id="colCustCity" prefWidth="180.0" text="City" />
                </columns>
            </TableView>

            <!-- Reload Button -->
            <Button fx:id="btnReload" onAction="#btnReloadOnAction" styleClass="reload-button" text="Reload" />

        </VBox>
    </children>
</AnchorPane>
